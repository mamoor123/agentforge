# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — used by webhook handlers for admin access (bypasses RLS).
# ⚠️ NEVER expose this to the client or commit it to source control.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Lemon Squeezy (optional — for paid listings) ────────────────────────────
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LS_FEATURED_VARIANT_ID=
LS_SPOTLIGHT_VARIANT_ID=
