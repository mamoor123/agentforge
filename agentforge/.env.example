# Lemon Squeezy Configuration
# Get these from your Lemon Squeezy dashboard: https://app.lemonsqueezy.com

# API Key (Settings > API)
LEMONSQUEEZY_API_KEY=your_api_key_here

# Store ID (Settings > Stores > your store)
LEMONSQUEEZY_STORE_ID=your_store_id

# Webhook Secret (Settings > Webhooks > your endpoint)
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret

# Product Variant IDs
# Create products in Lemon Squeezy dashboard:
#   1. "Featured Listing" — $75/month subscription
#   2. "Spotlight Listing" — $200/month subscription
# Then copy the variant IDs from each product's page
LS_FEATURED_VARIANT_ID=your_featured_variant_id
LS_SPOTLIGHT_VARIANT_ID=your_spotlight_variant_id

# Site URL (used for redirect URLs)
NEXT_PUBLIC_SITE_URL=https://agentforge.ai
